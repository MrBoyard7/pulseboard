# Copy this file to .env and adjust the values for your environment.

APP_NAME=PulseBoard API
ENVIRONMENT=development
DEBUG=true

# Generate a strong secret with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

DATABASE_URL=postgresql+psycopg2://pulseboard:pulseboard@localhost:5432/pulseboard

ALLOWED_ORIGINS=["http://localhost:5173"]
